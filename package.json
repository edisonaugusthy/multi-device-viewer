{
  "name": "multi-device-viewer",
  "version": "0.1.5",
  "description": "A local-first Chrome extension for mobile view and responsive device testing across phones, tablets, laptops, and desktops.",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:preview": "vite --config vite.preview.config.ts",
    "build": "wxt build",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "validate:chrome-zip": "node scripts/validate-chrome-extension-package.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.25"
  }
}
